# Supabase (publishable / anon key — safe in client bundles, but keep this file out of git per .gitignore)
VITE_SUPABASE_PROJECT_ID=""
VITE_SUPABASE_PUBLISHABLE_KEY=""
VITE_SUPABASE_URL=""

# Mapbox public token. Restrict to your domains in the Mapbox dashboard.
# Rotate the previously-hardcoded token before any production exposure.
VITE_MAPBOX_PUBLIC_TOKEN=""

# Cloudflare Turnstile (Phase 2.11 — denomination change captcha)
VITE_TURNSTILE_SITE_KEY=""

# NEVER put server-side secrets in this file. Service-role keys, OPENAI_API_KEY,
# RESEND_API_KEY, ELEVENLABS_API_KEY, VAPID keys, FUNCTION_SECRET, TURNSTILE_SECRET_KEY,
# STRIPE_SECRET_KEY, etc. live in Supabase Edge Function secrets.
